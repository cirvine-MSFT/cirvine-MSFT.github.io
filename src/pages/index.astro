---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SocialIcon from '../components/SocialIcon.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="text-center py-20">
    <h1 class="text-5xl font-bold mb-4">
      <span style="color: var(--color-text-primary);">Casey</span>
      <span class="neon-green-glow"> Irvine</span>
    </h1>
    <p class="text-xl mb-6" style="color: var(--color-text-secondary);">
      Software Engineer · Making it up as I go along
    </p>

    <!-- Social icons -->
    <div class="flex justify-center gap-5 mb-8">
      <a href="https://github.com/cirvine-MSFT" target="_blank" rel="noopener" class="social-icon" title="GitHub">
        <SocialIcon name="github" size={28} />
      </a>
      <a href="https://youtube.com/@CaseyIrvine" target="_blank" rel="noopener" class="social-icon" title="YouTube">
        <SocialIcon name="youtube" size={28} />
      </a>
      <a href="https://linkedin.com/in/caseyirvine" target="_blank" rel="noopener" class="social-icon" title="LinkedIn">
        <SocialIcon name="linkedin" size={28} />
      </a>
    </div>

    <div class="flex justify-center gap-4">
      <a href="/articles" class="inline-block px-6 py-3 rounded-lg text-sm font-semibold transition-all duration-300"
        style="background: var(--color-accent-green); color: var(--color-bg-primary); box-shadow: var(--glow-green);">
        Read the Blog
      </a>
      <a href="/videos" class="inline-block px-6 py-3 rounded-lg text-sm font-semibold transition-all duration-300"
        style="border: 1px solid var(--color-accent-blue); color: var(--color-accent-blue);">
        Watch Videos
      </a>
    </div>
  </section>

  <!-- Recent articles -->
  {articles.length > 0 && (
    <section class="mt-12">
      <h2 class="text-2xl font-bold mb-6" style="color: var(--color-text-primary);">
        Recent Posts
      </h2>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {articles.map((article) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            pubDate={article.data.pubDate.toISOString()}
            slug={article.id}
            tags={article.data.tags}
          />
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/articles" class="text-sm" style="color: var(--color-accent-blue);">
          View all articles →
        </a>
      </div>
    </section>
  )}
</BaseLayout>
