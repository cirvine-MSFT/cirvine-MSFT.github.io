---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
---

<BaseLayout title="Blog" description="Articles on software engineering, AI, developer tools, and making it up as I go along.">
  <h1 class="text-4xl font-bold mb-2" style="color: var(--color-text-primary);">Blog</h1>
  <p class="mb-10" style="color: var(--color-text-secondary);">
    Thoughts on software engineering, AI, developer tools, and whatever I'm tinkering with.
  </p>

  {articles.length === 0 ? (
    <div class="glass-card p-8 text-center">
      <p class="text-lg" style="color: var(--color-text-muted);">
        No articles yet — check back soon! 🎙️
      </p>
    </div>
  ) : (
    <div class="grid gap-6 md:grid-cols-2">
      {articles.map((article) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          pubDate={article.data.pubDate.toISOString()}
          slug={article.id}
          tags={article.data.tags}
        />
      ))}
    </div>
  )}
</BaseLayout>
