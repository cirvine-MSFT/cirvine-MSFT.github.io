---
interface Props {
  title: string;
  description: string;
  pubDate: string;
  slug: string;
  tags?: string[];
}

const { title, description, pubDate, slug, tags } = Astro.props;
const formattedDate = new Date(pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/articles/${slug}`} class="block glass-card p-6 group">
  <p class="text-xs uppercase tracking-widest mb-2" style="color: var(--color-text-muted);">
    {formattedDate}
  </p>
  <h3 class="text-lg font-semibold mb-2 group-hover:text-[var(--color-accent-green)] transition-colors" style="color: var(--color-text-primary);">
    {title}
  </h3>
  <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
    {description}
  </p>
  {tags && tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mt-4">
      {tags.map((tag) => (
        <span class="text-xs px-2 py-0.5 rounded-full" style="background: rgba(57,255,20,0.08); color: var(--color-accent-green);">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
