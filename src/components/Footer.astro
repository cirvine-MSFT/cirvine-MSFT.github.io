---
const year = new Date().getFullYear();
---

<footer class="relative z-20 w-full border-t mt-20 py-8 px-6" style="border-color: rgba(255,255,255,0.06);">
  <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm" style="color: var(--color-text-muted);">
    <p>&copy; {year} Casey Irvine</p>
    <div class="flex gap-5">
      <a href="https://github.com/cirvine-MSFT" target="_blank" rel="noopener" style="color: var(--color-text-secondary);">GitHub</a>
      <a href="https://youtube.com/@caseyirvine" target="_blank" rel="noopener" style="color: var(--color-text-secondary);">YouTube</a>
      <a href="/rss.xml" style="color: var(--color-text-secondary);">RSS</a>
    </div>
  </div>
</footer>
