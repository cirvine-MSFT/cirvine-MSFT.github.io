---
interface Props {
  id: string;
  title?: string;
}

const { id, title = 'YouTube video' } = Astro.props;
---

<div class="relative w-full rounded-lg overflow-hidden" style="aspect-ratio: 16/9; border: 1px solid rgba(255,255,255,0.06); box-shadow: var(--glow-blue);">
  <iframe
    src={`https://www.youtube-nocookie.com/embed/${id}`}
    title={title}
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
    loading="lazy"
    class="absolute inset-0 w-full h-full"
    style="border: none;"
  />
</div>
